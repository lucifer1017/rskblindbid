NEXT_PUBLIC_PARA_API_KEY=get-your-api-key-from-para-devportal

NEXT_PUBLIC_ROOTSTOCK_TESTNET_RPC_URL=get-it-from-https://dashboard.rpc.rootstock.io/

NEXT_PUBLIC_PARA_ENVIRONMENT=can-be-BETA-or-PROD

# Strongly recommended with Para + EVM wallets (MetaMask list in modal): free WalletConnect Cloud project id.
# Without it, Para logs a console warning and WC-only wallets (e.g. Rainbow) may not work reliably.
# https://cloud.walletconnect.com/
# NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=